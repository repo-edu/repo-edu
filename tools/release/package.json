{
  "name": "@repo-edu/release",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "license-gate": "tsx src/license-gate-cli.ts",
    "macos-signing:prepare": "tsx src/macos-signing-prepare-cli.ts",
    "macos-signing:cleanup": "tsx src/macos-signing-cleanup-cli.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm run typecheck"
  },
  "dependencies": {
    "@repo-edu/tree-sitter-grammar-assets": "workspace:*",
    "license-checker-rseidelsohn": "5.0.1",
    "spdx-expression-parse": "4.0.0",
    "spdx-license-list": "6.11.0",
    "spdx-satisfies": "6.0.0"
  }
}
