{
  "name": "@repo-edu/architecture-check",
  "private": true,
  "type": "module",
  "dependencies": {
    "@types/d3-hierarchy": "3.1.7",
    "@types/html-escaper": "3.0.4",
    "d3-hierarchy": "3.1.2",
    "dependency-cruiser": "17.4.3",
    "html-escaper": "3.0.3",
    "open": "11.0.0",
    "typescript": "6.0.2",
    "zod": "4.4.3"
  },
  "scripts": {
    "overview": "pnpm run check && tsx src/overview.ts",
    "start": "pnpm run check && tsx src/main.ts",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm run typecheck && pnpm run test"
  }
}
