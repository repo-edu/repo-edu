        { "type": "pattern", "path": "^packages/renderer-app/src/session/" },
        { "type": "pattern", "path": "^packages/renderer-app/src/persistence/" },
        { "type": "pattern", "path": "^packages/renderer-app/src/analysis/" },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/components/tabs/(AnalysisTab|ExaminationTab|SubmissionExaminationTab|GroupsAssignmentsTab|StudentsTab)\\.tsx$"
