      "id": "tool-sweep",
      "name": "File-growth sweep tool",
      "kind": "partition",
      "members": [{ "type": "pattern", "path": "^tools/sweep/src/" }]
    },
    {
      "id": "cover-analysis-workflow",
      "name": "Analysis workflow",
      "kind": "cover",
      "members": [
        { "type": "pattern", "path": "^packages/domain/src/analysis/" },
        { "type": "file", "path": "packages/domain/src/analysis-inputs.ts" },
        { "type": "file", "path": "packages/domain/src/analysis-input-types.ts" },
        { "type": "pattern", "path": "^packages/application/src/analysis-workflows/" },
        { "type": "pattern", "path": "^packages/application/src/__tests__/(analysis|blame)" },
        { "type": "pattern", "path": "^packages/renderer-app/src/analysis/" },
        { "type": "pattern", "path": "^packages/renderer-app/src/components/tabs/AnalysisTab\\.tsx$" },
        { "type": "pattern", "path": "^packages/renderer-app/src/components/tabs/analysis/" },
        { "type": "file", "path": "packages/renderer-app/src/source-tokenizer.ts" },
        { "type": "pattern", "path": "^packages/tree-sitter-grammar-assets/src/" },
        { "type": "pattern", "path": "^apps/docs/src/fixtures/" },
        { "type": "pattern", "path": "^apps/docs/src/__tests__/(analysis|fixture-workflow|runtime-selection)" },
        { "type": "file", "path": "apps/docs/src/demo-runtime.ts" }
      ]
    },
    {
      "id": "cover-examination-workflow",
      "name": "Examination workflow",
      "kind": "cover",
      "members": [
        { "type": "pattern", "path": "^packages/application/src/examination-workflows/" },
        { "type": "pattern", "path": "^packages/application/src/__tests__/examination" },
        { "type": "file", "path": "packages/application-contract/src/examination-contract.ts" },
        { "type": "pattern", "path": "^packages/renderer-app/src/components/tabs/(ExaminationTab|SubmissionExaminationTab)\\.tsx$" },
        { "type": "pattern", "path": "^packages/renderer-app/src/components/tabs/examination/" },
        { "type": "pattern", "path": "^packages/renderer-app/src/stores/examination" },
        { "type": "pattern", "path": "^packages/renderer-app/src/__tests__/examination" }
      ]
    },
    {
      "id": "cover-llm-runtime",
      "name": "LLM runtime",
      "kind": "cover",
      "members": [
        { "type": "pattern", "path": "^packages/integrations-llm/src/" },
        { "type": "pattern", "path": "^packages/integrations-llm-contract/src/" },
        { "type": "pattern", "path": "^packages/integrations-llm-catalog/src/" },
        { "type": "pattern", "path": "^packages/claude-coder/src/" },
        { "type": "pattern", "path": "^packages/fixture-engine/src/(coder|fixture|llm|planner|prompt|review|state|evaluate|sampler|sweep|defaults|fixture-commands|index|cli|constants|log|markers|naming|plan-md|project-md|repo-context)" },
        { "type": "file", "path": "packages/domain/src/settings.ts" },
        { "type": "file", "path": "packages/domain/src/__tests__/settings-llm.test.ts" },
        { "type": "pattern", "path": "^packages/application-contract/src/(examination-contract|workflow-catalog|workflow-payloads|workflow-types)\\.ts$" },
        { "type": "file", "path": "packages/host-runtime-contract/src/index.ts" },
        { "type": "pattern", "path": "^apps/desktop/src/.*llm" },
        { "type": "pattern", "path": "^packages/host-node/src/.*llm" },
        { "type": "pattern", "path": "^packages/application/src/(llm-connection-workflows|llm-error-normalization)\\.ts$" },
        { "type": "pattern", "path": "^packages/application/src/examination-workflows/(examination-workflows|model-resolution|ports|prompt-builder|provider-excerpts|question-parser|redaction|soft-stop-session)\\.ts$" },
        { "type": "pattern", "path": "^packages/application/src/__tests__/(llm|examination-llm|examination-prompt|examination-redaction|examination-streaming)" },
        { "type": "pattern", "path": "^packages/renderer-app/src/components/settings/.*Llm" },
        { "type": "pattern", "path": "^packages/renderer-app/src/components/tabs/examination/(LlmControls|llm-models)\\.ts" },
        { "type": "pattern", "path": "^packages/renderer-app/src/stores/(credentials-store|connections-store|examination-preferences)\\.ts$" },
        { "type": "pattern", "path": "^apps/docs/src/(demo-runtime|components/DemoApp)\\.tsx?$" },
        { "type": "pattern", "path": "^packages/host-browser-mock/src/" }
      ]
    }
  ]
