          "type": "pattern",
          "path": "^packages/renderer-app/src/utils/(course-navigation|export-group-set|history-boundary|lms-provider|repository-workflow)\\.ts$"
        },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/__tests__/(course-navigation|history-boundary|repository-workflow|use-courses)"
        }
