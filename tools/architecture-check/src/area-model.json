      "id": "tool-release",
      "name": "Release tool",
      "kind": "partition",
      "members": [{ "type": "pattern", "path": "^tools/release/src/" }],
      "exclude": [
        { "type": "pattern", "path": "^tools/release/src/license-gate\\.ts$" },
        {
          "type": "pattern",
          "path": "^tools/release/src/license-gate-cli\\.ts$"
