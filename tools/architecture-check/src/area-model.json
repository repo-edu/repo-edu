      "name": "Renderer groups and roster",
      "kind": "partition",
      "members": [
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/components/tabs/(GroupsAssignmentsTab|StudentsTab)\\.tsx$"
        },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/components/tabs/(groups-assignments|students)/"
        },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/components/dialogs/(AddGroupDialog|ConnectLmsGroupSetDialog|CopyGroupSetDialog|DeleteGroupDialog|DeleteGroupSetDialog|ImportGitUsernamesDialog|ImportGroupSetDialog|ImportStudentsFromFileDialog|LmsImportConflictDialog|NewAssignmentDialog|NewLocalGroupSetDialog|PreflightDialog|StudentMultiSelect|StudentSyncDialog|UsernameVerificationDialog|ValidationDialog)\\.tsx$"
