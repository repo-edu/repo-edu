      "name": "Renderer analysis",
      "kind": "partition",
      "members": [
        { "type": "pattern", "path": "^packages/renderer-app/src/analysis/" },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/components/tabs/AnalysisTab\\.tsx$"
