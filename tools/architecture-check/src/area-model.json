        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/components/tabs/analysis/"
        },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/hooks/use-analysis-context\\.ts$"
        },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/source-tokenizer\\.ts$"
        },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/stores/analysis-store\\.ts$"
        },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/utils/(analysis-[^/]*|author-colors|blame-[^/]*|token-estimate)\\.ts$"
        },
        {
          "type": "pattern",
          "path": "^packages/renderer-app/src/__tests__/(analysis|blame|process-blame-lines)"
        }
