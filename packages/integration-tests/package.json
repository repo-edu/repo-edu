{
  "name": "@repo-edu/integration-tests",
  "private": true,
  "type": "module",
  "dependencies": {
    "@repo-edu/application": "workspace:*",
    "@repo-edu/domain": "workspace:*",
    "@repo-edu/host-node": "workspace:*",
    "@repo-edu/host-runtime-contract": "workspace:*",
    "@repo-edu/integrations-git": "workspace:*",
    "@repo-edu/integrations-git-contract": "workspace:*",
    "@repo-edu/test-fixtures": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  },
  "scripts": {
    "test:integration": "node --import tsx --test src/repo-create.test.ts",
    "docker:up": "docker compose up -d --wait && (docker compose exec -T -u git gitea gitea admin user create --admin --username test-admin --password test-admin-pw --email admin@test.local --must-change-password=false || true)",
    "docker:down": "docker compose down -v --remove-orphans"
  }
}
