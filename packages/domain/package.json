    },
    "./roster-lms-merge": {
      "source": "./src/roster-lms-merge.ts",
      "types": "./dist/roster-lms-merge.d.ts",
      "default": "./dist/roster-lms-merge.js"
    },
    "./roster-reconciliation": {
      "source": "./src/roster-reconciliation.ts",
      "types": "./dist/roster-reconciliation.d.ts",
