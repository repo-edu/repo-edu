{
  "name": "@repo-edu/host-node",
  "private": true,
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@repo-edu/host-runtime-contract": "workspace:*"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cache": {
      "source": "./src/cache/index.ts",
      "types": "./dist/cache/index.d.ts",
      "default": "./dist/cache/index.js"
    },
    "./examination-archive": {
      "source": "./src/examination-archive/index.ts",
      "types": "./dist/examination-archive/index.d.ts",
      "default": "./dist/examination-archive/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "check": "pnpm run typecheck",
    "test": "node --import tsx --test src/**/__tests__/*.test.ts"
  }
}
