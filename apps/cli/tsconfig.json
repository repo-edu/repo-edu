{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./.tsbuildinfo",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "package.json"
  ],
  "references": [
    {
      "path": "../../packages/application-contract"
    },
    {
      "path": "../../packages/application"
    },
    {
      "path": "../../packages/host-node"
    },
    {
      "path": "../../packages/integrations-git"
    },
    {
      "path": "../../packages/integrations-lms"
    },
    {
      "path": "../../packages/test-fixtures"
    }
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
