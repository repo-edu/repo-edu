{
  "name": "@repo-edu/desktop",
  "private": true,
  "type": "module",
  "main": "./out/main/main.js",
  "dependencies": {
    "@repo-edu/app": "workspace:*",
    "@repo-edu/application": "workspace:*",
    "@repo-edu/application-contract": "workspace:*",
    "@repo-edu/domain": "workspace:*",
    "@repo-edu/host-node": "workspace:*",
    "@repo-edu/host-runtime-contract": "workspace:*",
    "@repo-edu/integrations-git": "workspace:*",
    "@repo-edu/integrations-lms": "workspace:*",
    "@repo-edu/renderer-host-contract": "workspace:*",
    "@repo-edu/test-fixtures": "workspace:*",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "electron": "^35.7.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "trpc-electron": "^0.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.2.1"
  },
  "scripts": {
    "build": "electron-vite build",
    "build:types": "tsc -b tsconfig.json",
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "validate:trpc": "node ./scripts/validate-trpc-spike.mjs",
    "validate:shell-boundary": "node ./scripts/validate-shell-boundary.mjs",
    "validate:runtime": "pnpm run build && pnpm run validate:trpc && pnpm run validate:shell-boundary",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "check": "pnpm run typecheck",
    "test": "node --test"
  }
