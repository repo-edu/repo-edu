{
    "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
    "appId": "edu.repo.desktop",
    "productName": "RepoEdu",
    "artifactName": "RepoEdu-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "npmRebuild": false,
    "directories": {
        "output": "release"
    },
    "files": [
        "out/main/**/*",
        "out/preload/**/*",
        "out/renderer/**/*",
        "package.json"
    ],
    "extraMetadata": {
        "main": "./out/main/main.js",
        "dependencies": {}
    },
    "publish": {
        "provider": "github",
        "owner": "repo-edu",
        "repo": "repo-edu"
    },
    "mac": {
        "category": "public.app-category.developer-tools",
        "executableName": "RepoEdu",
        "target": [
            "dmg",
            "zip"
        ],
        "notarize": true
    },
    "nsis": {
        "oneClick": true,
        "perMachine": false
    },
    "win": {
        "executableName": "RepoEdu",
        "target": [
            "nsis"
        ]
    },
    "linux": {
        "executableName": "repo-edu",
        "target": [
            "AppImage",
            "deb"
        ],
        "category": "Development",
        "maintainer": "RepoEdu Maintainers <opensource@repo-edu.dev>"
    }
}
