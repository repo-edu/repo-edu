{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2024",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@repo-edu/ui": ["./packages/ui/src/index.ts"],
      "@repo-edu/ui/components/icons": [
        "./packages/ui/src/components/icons.ts"
      ],
      "@repo-edu/ui/components/ui/*": [
        "./packages/ui/src/components/ui/*"
      ],
      "@repo-edu/ui/lib/*": ["./packages/ui/src/lib/*"],
      "@repo-edu/renderer-app": ["./packages/renderer-app/src/index.ts"],
      "@repo-edu/domain/types": ["./packages/domain/src/types.ts"],
      "@repo-edu/domain/settings": ["./packages/domain/src/settings.ts"],
      "@repo-edu/domain/roster": ["./packages/domain/src/roster.ts"],
      "@repo-edu/domain/roster-lms-merge": [
        "./packages/domain/src/roster-lms-merge.ts"
      ],
      "@repo-edu/domain/group-set": ["./packages/domain/src/group-set.ts"],
      "@repo-edu/domain/group-set-import-export": [
        "./packages/domain/src/group-set-import-export.ts"
      ],
      "@repo-edu/domain/group-selection": [
        "./packages/domain/src/group-selection.ts"
      ],
      "@repo-edu/domain/repository-planning": [
        "./packages/domain/src/repository-planning.ts"
      ],
      "@repo-edu/domain/validation": [
        "./packages/domain/src/validation.ts"
      ],
      "@repo-edu/domain/schemas": ["./packages/domain/src/schemas.ts"],
      "@repo-edu/application-contract": [
        "./packages/application-contract/src/index.ts"
      ],
      "@repo-edu/application": ["./packages/application/src/index.ts"],
      "@repo-edu/renderer-host-contract": [
        "./packages/renderer-host-contract/src/index.ts"
      ],
      "@repo-edu/host-runtime-contract": [
        "./packages/host-runtime-contract/src/index.ts"
      ],
      "@repo-edu/integrations-lms-contract": [
        "./packages/integrations-lms-contract/src/index.ts"
      ],
      "@repo-edu/integrations-git-contract": [
        "./packages/integrations-git-contract/src/index.ts"
      ],
      "@repo-edu/host-node": ["./packages/host-node/src/index.ts"],
      "@repo-edu/host-browser-mock": [
        "./packages/host-browser-mock/src/index.ts"
      ],
      "@repo-edu/test-fixtures": [
        "./packages/test-fixtures/src/index.ts"
      ],
      "@repo-edu/integrations-lms": [
        "./packages/integrations-lms/src/index.ts"
      ],
      "@repo-edu/integrations-git": ["./packages/integrations-git/src/index.ts"]
    }
  }
}
