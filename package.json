{
    "name": "repo-edu",
    "private": true,
    "scripts": {
        "// ---- dev & build ----": "",
        "dev": "pnpm --filter @repo-edu/desktop run dev",
        "build": "pnpm --filter @repo-edu/desktop run package:app",
        "build:cli": "bun build --compile --target=bun-darwin-arm64 apps/cli/src/main.ts --outfile apps/cli/dist/redu && printf 'Built CLI: %s\\n' \"$PWD\"/apps/cli/dist/redu",
        "redu": "./apps/cli/dist/redu",
        "// ---- format ----": "",
        "fmt": "pnpm fmt:ts && pnpm fmt:md",
        "fmt:ts": "biome format --write",
        "fmt:md": "rumdl fmt",
        "fmt:check": "pnpm fmt:ts:check && pnpm fmt:md:check",
        "fmt:ts:check": "biome format .",
        "fmt:md:check": "rumdl fmt --check",
        "// ---- lint ----": "",
        "fix": "pnpm lint:fix",
        "lint": "pnpm lint:ts && pnpm lint:md",
        "lint:ts": "biome lint .",
        "lint:fix": "biome lint --write .",
        "lint:md": "rumdl check",
        "// ---- check ----": "",
        "typecheck": "pnpm -r run typecheck",
        "check": "pnpm fmt:check && pnpm lint && pnpm typecheck && pnpm check:types:build && pnpm check:fixtures && pnpm check:architecture",
        "check:types:build": "tsc -b tsconfig.json",
        "check:fixtures": "pnpm exec tsx scripts/check-fixtures.ts",
        "check:architecture": "pnpm exec tsx scripts/check-architecture.ts",
        "// ---- test ----": "",
        "test": "pnpm -r --if-present run test",
        "test:runtime": "pnpm --filter @repo-edu/desktop run validate:runtime",
        "test:all": "pnpm test && pnpm test:runtime",
        "// ---- test git integration using docker ----": "",
        "test:integration": "pnpm test:integration:gitea",
        "test:integration:gitea": "sh -c 'GITEA_PORT=${GITEA_PORT:-3000}; pnpm --filter @repo-edu/integration-tests run docker:up:gitea || exit $?; INTEGRATION_GIT_PROVIDERS=gitea INTEGRATION_GITEA_URL=${INTEGRATION_GITEA_URL:-http://localhost:${GITEA_PORT}} pnpm --filter @repo-edu/integration-tests run test:integration; status=$?; pnpm --filter @repo-edu/integration-tests run docker:down || true; exit $status'",
        "test:integration:gitlab": "sh ./scripts/test-integration-gitlab.sh",
        "test:integration:gitlab:up": "pnpm --filter @repo-edu/integration-tests run docker:up:gitlab",
        "test:integration:gitlab:run": "sh ./scripts/test-integration-gitlab-run.sh",
        "test:integration:gitlab:down": "pnpm --filter @repo-edu/integration-tests run docker:down",
        "test:integration:github": "sh -c 'INTEGRATION_GIT_PROVIDERS=github pnpm --filter @repo-edu/integration-tests run test:integration'",
        "// ---- preflight release validation ----": "",
        "validate": "pnpm check && pnpm test:all",
        "// ---- docs ----": "",
        "docs:dev": "pnpm --filter @repo-edu/docs run dev",
        "docs:build": "pnpm --filter @repo-edu/docs run build",
        "docs:preview": "pnpm --filter @repo-edu/docs run build && pnpm --filter @repo-edu/docs run preview",
        "docs:test": "pnpm --filter @repo-edu/docs run test",
        "// ---- release ----": "",
        "release": "pnpm exec tsx scripts/release.ts",
        "release:patch": "pnpm exec tsx scripts/release.ts patch",
        "release:minor": "pnpm exec tsx scripts/release.ts minor",
        "release:major": "pnpm exec tsx scripts/release.ts major",
        "// ---- utilities ----": "",
        "file-sizes": "pnpm exec tsx scripts/file-sizes.ts",
        "claude2assistants": "node scripts/claude2assistants.mjs",
        "pnpm:update": "pnpm self-update",
        "deps:latest": "pnpm up -r --latest && pnpm dedupe"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.8",
        "@faker-js/faker": "^10.3.0",
        "@types/node": "25.5.0",
        "bun": "^1.3.11",
        "globby": "^16.1.1",
        "rumdl": "0.1.59",
        "tsx": "^4.21.0",
        "typescript": "6.0.2"
    }
}
