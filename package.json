{
    "name": "repo-edu",
    "private": true,
    "packageManager": "pnpm@10.28.0",
    "scripts": {
        "dev": "pnpm --filter @repo-edu/desktop run dev",
        "build": "pnpm -r run build",
        "fmt:ts": "biome format --write",
        "lint:ts": "biome check",
        "lint:fix": "biome check --write .",
        "lint:md": "rumdl check",
        "lint": "biome check . && rumdl check",
        "fmt:md": "rumdl fmt",
        "fmt": "pnpm fmt:ts && pnpm fmt:md",
        "fix": "pnpm lint:fix",
        "typecheck": "pnpm -r run typecheck",
        "build:types": "tsc -b tsconfig.json",
        "check": "pnpm lint && pnpm typecheck && pnpm build:types && pnpm fixture:check",
        "test": "pnpm test:workspace",
        "test:workspace": "pnpm -r --if-present run test",
        "test:runtime": "pnpm --filter @repo-edu/desktop run validate:runtime",
        "test:all": "pnpm test:workspace && pnpm test:runtime",
        "validate": "pnpm check && pnpm test",
        "desktop:test": "pnpm test:runtime",
        "cli:build": "pnpm --filter @repo-edu/cli run build",
        "fixture:constraints": "pnpx tsx scripts/create-fixture-constraints.ts",
        "fixture:create": "pnpm fixture:constraints && cd ../test-fixtures && claude /create-students-repo",
        "fixture:generate": "pnpm exec tsx scripts/generate-docs-fixtures.ts",
        "fixture:validate": "pnpm exec tsx scripts/validate-docs-fixtures.ts",
        "fixture:check": "pnpm exec tsx scripts/check-docs-fixtures.ts",
        "fixture:docs:generate": "pnpm fixture:generate",
        "fixture:docs:validate": "pnpm fixture:validate",
        "fixture:docs:check": "pnpm fixture:check",
        "docs:dev": "pnpm --filter @repo-edu/docs run dev",
        "docs:build": "pnpm --filter @repo-edu/docs run build",
        "docs:preview": "pnpm --filter @repo-edu/docs run build && pnpm --filter @repo-edu/docs run preview",
        "docs:test": "pnpm --filter @repo-edu/docs run test",
        "claude2assistants": "node scripts/claude2assistants.mjs"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.14",
        "@faker-js/faker": "^10.3.0",
        "@types/node": "22.18.11",
        "globby": "^16.1.1",
        "tsx": "^4.21.0",
        "typescript": "5.9.3"
    }
}
