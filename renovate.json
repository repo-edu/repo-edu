{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Amsterdam",
  "schedule": ["* 0-4 1 */2 *"],
  "dependencyDashboard": true,
  "prConcurrentLimit": 3,
  "prHourlyLimit": 2,
  "automerge": true,
  "automergeType": "branch",
  "automergeStrategy": "fast-forward",
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 0-4 2 */2 *"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"],
    "prConcurrentLimit": 0,
    "prHourlyLimit": 0
  },
  "packageRules": [
    {
      "description": "Batch the long tail of non-major updates into one bi-monthly fast-forward",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "non-major dependencies"
    },
    {
      "description": "Electron runtime patch/minor updates: weekly with a short maturity window because Electron carries Chromium and has a short support cycle",
      "matchPackageNames": ["electron"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "electron runtime non-major",
      "schedule": ["* 0-4 * * 1"],
      "minimumReleaseAge": "2 days"
    },
    {
      "description": "Fast-moving, peer-coupled AI SDKs: monthly (8th), grouped so they move in lockstep",
      "matchPackageNames": ["@anthropic-ai/**", "@modelcontextprotocol/sdk"],
      "groupName": "ai sdks",
      "schedule": ["* 0-4 8 * *"]
    },
    {
      "description": "Major bumps: wait 30 days for the release to mature so others hit the early bugs, then take the same automatic fast-forward",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "30 days"
    },
    {
      "description": "Electron runtime major updates: monthly so the app does not drift into Electron's oldest supported line",
      "matchPackageNames": ["electron"],
      "matchUpdateTypes": ["major"],
      "groupName": "electron runtime major",
      "schedule": ["* 0-4 15 * *"],
      "minimumReleaseAge": "7 days"
    }
  ]
}
