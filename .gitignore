# Git, useful for VSCode and other tools
.git/

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# Test artifacts
.test-config/
apps/desktop/test-results/
apps/desktop/playwright-report/

# AI assistants
.claude/settings.local.json
.gemini-clipboard/

# Planning files and notes
.claude/plan
plan/

# Binding generation cache
.bindings-hash

# Tools
.rumdl_cache/

# pnpm sweep state (tool-owned, never committed)
tools/sweep/skip-cache
tools/sweep/refactor-todo

# Dependencies
.pnpm-store/
node_modules/

# Build outputs
target/
dist/
out/
release/
!tools/release/
!tools/release/**
tools/release/node_modules/
site/
*.tsbuildinfo
apps/docs/.astro/

# Inline TypeScript compilation outputs (*.js / *.d.ts / *.d.ts.map emitted next to source)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
apps/docs/src/**/*.js

# Hand-authored ambient declarations (source, not emitted output)
!packages/renderer-app/src/wasm-url.d.ts

# Logs
*.log

# Generated via pnpm claude2assistants
AGENTS.md
GEMINI.md

# Link to /Users/Shared
shared
